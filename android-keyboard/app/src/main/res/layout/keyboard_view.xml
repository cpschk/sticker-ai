<?xml version="1.0" encoding="utf-8"?>
<!-- FrameLayout raíz para poder superponer el FAB sobre el teclado -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#D1D5DB">

        <!-- Barra de sugerencias de stickers -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#F3F4F6"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/suggestion_bar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp" />
        </HorizontalScrollView>

        <!-- Filas de teclas construidas programáticamente -->
        <LinearLayout
            android:id="@+id/keys_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="3dp"
            android:paddingEnd="3dp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

    <!-- ── FAB principal (esquina superior derecha) ── -->
    <ImageView
        android:id="@+id/fab_sticker"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:src="@android:drawable/ic_menu_add"
        android:scaleType="center"
        android:background="@drawable/fab_bg"
        android:elevation="8dp"
        android:contentDescription="Sugerir sticker" />

    <!-- ── Contenedor de los 3 sticker bubbles — horizontal hacia la izquierda ── -->
    <LinearLayout
        android:id="@+id/fab_sticker_container"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:visibility="gone"
        android:elevation="7dp" />

</FrameLayout>
